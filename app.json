{
  "expo": {
    /* Basic app identity and versioning */
    "name": "BreatheSafe",
    "slug": "BreatheSafe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/logo.png",
    
    /* URL scheme for deep linking and theme settings */
    "scheme": "breathesafefront",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    /* Platform-specific settings for iOS and Android */
    "ios": {
      "supportsTablet": true
    },
    "android": {
      /* Adaptive icon configuration for modern Android versions */
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },

    /* Web-specific bundling and static output settings */
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/logo.png"
    },

    /* Plugin integration for Router and Splash Screen appearance */
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],

    /* Experimental features for TypeScript safety and performance */
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}